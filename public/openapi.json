{
  "openapi": "3.0.3",
  "info": {
    "title": "API Películas & Series Latino",
    "version": "1.0.0",
    "description": "API REST en vivo para consultar catálogos estilo Netflix, metadatos y reproductores embeds verificados de películas, series, animes y doramas en audio Latino."
  },
  "servers": [
    {
      "url": "https://api-pelis-series-latino.vercel.app",
      "description": "Servidor de Producción Vercel"
    }
  ],
  "paths": {
    "/api/v1/panel": {
      "get": {
        "summary": "Obtener fuentes activas y su orden de prioridad",
        "description": "Retorna el listado de proveedores de scraping configurados (TioPlus, FuegoCine, Supabase), con su estado (activada/desactivada) y prioridad.",
        "responses": {
          "200": {
            "description": "Estado del panel obtenido con éxito"
          }
        }
      }
    },
    "/api/v1/panel/sources": {
      "post": {
        "summary": "Actualizar activación y prioridad de fuentes de catálogo",
        "description": "Permite activar/desactivar proveedores y ajustar su orden de prioridad para determinar qué servidores aparecen primero en la unificación.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sources": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "enabled": { "type": "boolean" },
                        "priority": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fuentes actualizadas exitosamente"
          }
        }
      }
    },
    "/api/v1/search": {
      "get": {
        "summary": "Búsqueda general en tiempo real",
        "description": "Busca películas, series, animes y doramas por título u alias. Si es una película (`type: movie`), incluye sus servidores embed. Si es una serie (`type: tvseries`), incluye `seasons` con la estructura de temporadas y episodios.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Término de búsqueda (ej. avatar, dragon ball, la casa del dragon)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Búsqueda exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/media/{id}": {
      "get": {
        "summary": "Obtener detalle por Slug o ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Slug o ID del contenido (ej. scary-movie-6, la-casa-del-dragon)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalle obtenido con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaItemResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/series/{id}/season/{season}/episode/{episode}": {
      "get": {
        "summary": "Obtener servidores de streaming para un episodio específico de una serie",
        "description": "Devuelve los reproductores de video embed reales (VidHide, Netu, UPFAST, etc.) para la temporada y episodio indicados de la serie.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Slug de la serie (ej. la-casa-del-dragon)",
            "schema": { "type": "string" }
          },
          {
            "name": "season",
            "in": "path",
            "required": true,
            "description": "Número de temporada (ej. 1)",
            "schema": { "type": "integer" }
          },
          {
            "name": "episode",
            "in": "path",
            "required": true,
            "description": "Número de episodio (ej. 1)",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Servidores del episodio obtenidos con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeDetailResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/home": {
      "get": {
        "summary": "Obtener feed principal estilo Netflix (Alias)",
        "responses": { "200": { "description": "Feed obtenido con éxito" } }
      }
    },
    "/api/v1/feeds/home": {
      "get": {
        "summary": "Obtener feed principal estilo Netflix",
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "default": "CL" }
          }
        ],
        "responses": { "200": { "description": "Feed obtenido con éxito" } }
      }
    },
    "/api/v1/movies": {
      "get": {
        "summary": "Obtener catálogo de películas con paginación",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "genre", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Lista de películas obtenida con éxito" } }
      }
    },
    "/api/v1/series": {
      "get": {
        "summary": "Obtener catálogo de series con paginación",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "genre", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Lista de series obtenida con éxito" } }
      }
    },
    "/api/v1/media": {
      "get": {
        "summary": "Obtener catálogo general (películas + series)",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "type", "in": "query", "schema": { "type": "string" } },
          { "name": "genre", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Catálogo devuelto con éxito" } }
      }
    },
    "/api/v1/media/batch": {
      "get": {
        "summary": "Consultar múltiples contenidos en lote por IDs",
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "required": true,
            "description": "Lista de IDs separados por comas (ej. ?ids=558,94997,748783)",
            "schema": { "type": "string" }
          },
          {
            "name": "compact",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": { "200": { "description": "Lote de contenidos devuelto con éxito" } }
      }
    },
    "/api/v1/revalidate": {
      "get": {
        "summary": "Invalidar y revalidar la caché de borde y memoria",
        "responses": { "200": { "description": "Caché invalidado con éxito" } }
      }
    },
    "/api/v1/stream/proxy": {
      "get": {
        "summary": "Proxy de Streaming de Video con soporte nativo HTTP Range Requests (206 Partial Content)",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "URL directa de video (MP4 o M3U8 HLS)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "206": { "description": "Respuesta parcial de flujo de video (Range Request Seek)" },
          "200": { "description": "Flujo de video completo" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ServerOption": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "quality": { "type": "string", "example": "1080p" },
          "language": { "type": "string", "example": "latino" },
          "embed_url": { "type": "string", "example": "https://vidhideplus.com/v/f1kgebbi5bly" },
          "status": {
            "type": "string",
            "enum": ["online", "offline"],
            "description": "Estado de salud del servidor verificado en la capa de aplicación (Soft Errors). Los reproductores o clientes DEBEN IGNORAR O FILTRAR los servidores con status: 'offline'."
          },
          "last_checked": { "type": "string", "format": "date-time" }
        }
      },
      "Episode": {
        "type": "object",
        "properties": {
          "episode_number": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Los herederos del Dragón" },
          "still_path": { "type": "string", "nullable": true },
          "servers": { "type": "array", "items": { "$ref": "#/components/schemas/ServerOption" } }
        }
      },
      "Season": {
        "type": "object",
        "properties": {
          "season_number": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Temporada 1" },
          "episodes_count": { "type": "integer", "example": 10 },
          "episodes": { "type": "array", "items": { "$ref": "#/components/schemas/Episode" } }
        }
      },
      "MediaItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "la-casa-del-dragon" },
          "tmdb_id": { "type": "integer" },
          "type": { "type": "string", "enum": ["movie", "tvseries"], "description": "Determina si el contenido es película o serie. Para 'movie', consultar `servers`. Para 'tvseries', consultar `seasons` o la ruta de episodios." },
          "title": { "type": "string" },
          "original_title": { "type": "string" },
          "overview": { "type": "string" },
          "rating": { "type": "number" },
          "release_date": { "type": "string" },
          "genres": { "type": "array", "items": { "type": "string" } },
          "poster": { "type": "string", "nullable": true },
          "backdrop": { "type": "string", "nullable": true },
          "tagline": { "type": "string", "description": "Lema o eslogan oficial de TMDB" },
          "trailer": { "type": "string", "nullable": true, "description": "URL oficial de tráiler en YouTube (prioriza audio Latino)" },
          "cast": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Lista de nombres simples de actores del reparto (evita [object Object] en clientes)"
          },
          "cast_details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "character": { "type": "string" },
                "photo": { "type": "string", "nullable": true }
              }
            },
            "description": "Lista detallada del reparto enriquecida desde TMDB con fotos y nombres de personaje"
          },
          "servers": { "type": "array", "items": { "$ref": "#/components/schemas/ServerOption" }, "description": "Presente únicamente cuando type = movie" },
          "total_seasons": { "type": "integer", "description": "Presente únicamente cuando type = tvseries" },
          "total_episodes": { "type": "integer", "description": "Presente únicamente cuando type = tvseries" },
          "seasons": { "type": "array", "items": { "$ref": "#/components/schemas/Season" }, "description": "Lista de temporadas y episodios. Presente únicamente cuando type = tvseries" }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "success" },
          "query": { "type": "string" },
          "count": { "type": "integer" },
          "results": { "type": "array", "items": { "$ref": "#/components/schemas/MediaItem" } }
        }
      },
      "MediaItemResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "success" },
          "data": { "$ref": "#/components/schemas/MediaItem" }
        }
      },
      "EpisodeDetailResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "success" },
          "data": {
            "type": "object",
            "properties": {
              "series_id": { "type": "string" },
              "season_number": { "type": "integer" },
              "episode_number": { "type": "integer" },
              "servers": { "type": "array", "items": { "$ref": "#/components/schemas/ServerOption" } }
            }
          }
        }
      }
    }
  }
}
