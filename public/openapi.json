{
  "openapi": "3.0.3",
  "info": {
    "title": "API Películas & Series Latino",
    "version": "1.0.0",
    "description": "API REST en vivo para consultar catálogos estilo Netflix, metadatos y reproductores embeds verificados de películas, series, animes y doramas en audio Latino."
  },
  "servers": [
    {
      "url": "https://api-pelis-series-latino.vercel.app",
      "description": "Servidor de Producción Vercel"
    }
  ],
  "paths": {
    "/api/v1/panel": {
      "get": {
        "summary": "Obtener fuentes activas y su orden de prioridad",
        "description": "Retorna el listado de proveedores de scraping configurados (TioPlus, FuegoCine, Supabase), con su estado (activada/desactivada) y prioridad.",
        "responses": {
          "200": {
            "description": "Estado del panel obtenido con éxito"
          }
        }
      }
    },
    "/api/v1/panel/sources": {
      "post": {
        "summary": "Actualizar activación y prioridad de fuentes de catálogo",
        "description": "Permite activar/desactivar proveedores y ajustar su orden de prioridad para determinar qué servidores aparecen primero en la unificación.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sources": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "enabled": {
                          "type": "boolean"
                        },
                        "priority": {
                          "type": "number"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fuentes actualizadas exitosamente"
          }
        }
      }
    },
    "/api/v1/panel/media/search": {
      "get": {
        "summary": "Buscar títulos en TMDB para edición",
        "description": "Retorna coincidencia de películas y series en TMDB con sus TMDB IDs, posters y fechas para personalizar su portada.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Búsqueda en TMDB exitosa"
          }
        }
      }
    },
    "/api/v1/panel/media/{tmdb_id}/override": {
      "post": {
        "summary": "Establecer portada y backdrop personalizada",
        "description": "Guarda una URL de poster o backdrop personalizada para sustituir la oficial de TMDB.",
        "parameters": [
          {
            "name": "tmdb_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "custom_poster": {
                    "type": "string"
                  },
                  "custom_backdrop": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Override guardado exitosamente"
          }
        }
      },
      "delete": {
        "summary": "Restablecer portada y backdrop original",
        "parameters": [
          {
            "name": "tmdb_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Override eliminado exitosamente"
          }
        }
      }
    },
    "/api/v1/search": {
      "get": {
        "summary": "Búsqueda general en tiempo real",
        "description": "Busca películas, series, animes y doramas por título o alias sobre el catálogo indexado, con coincidencia por SUBSTRING (ej. `ma` encuentra `Matilda`). El ranking prioriza los títulos que EMPIEZAN con el término. Respuesta LEAN por defecto (id, título, póster, año, rating, géneros) para máxima velocidad: los servidores, el cast y las temporadas se obtienen al abrir el detalle (`/api/v1/media/{id}` o `/api/v1/series/{id}`). Usa `full=true` para el objeto completo, o `compact=true` para la proyección compacta. `total_results` es el total REAL de coincidencias en el catálogo (no el acumulado de la página) y junto con `has_more` y `next_page` habilita el scroll infinito.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Término de búsqueda (ej. avatar, dragon ball, la casa del dragon)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Número de página, empezando en 1.",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Cantidad de resultados por página. Alias compatible: size. Máximo 100.",
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 100
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Alias de limit para definir la cantidad de resultados por página. Máximo 100.",
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 100
            }
          },
          {
            "name": "full",
            "in": "query",
            "description": "Si es true, devuelve el MediaItem completo (con cast, servers y seasons) en lugar de la proyección lean por defecto.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "compact",
            "in": "query",
            "description": "Si es true, devuelve la proyección compacta (incluye primary_stream y servers).",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Búsqueda exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/media/{id}": {
      "get": {
        "summary": "Obtener detalle por Slug o ID (metadata instantánea)",
        "description": "Devuelve la ficha completa (sinopsis, imágenes, reparto, temporadas) desde la base de datos o la caché, sin esperar a la resolución de enlaces. El bloque `streams` indica si los servidores ya están listos o dónde pedirlos (`GET /api/v1/media/{id}/streams`), lo que permite abrir una ficha emergente al instante y resolver la reproducción solo cuando el usuario pulsa Reproducir. Usa `streams=wait` para el comportamiento bloqueante clásico (metadata + servidores en una sola respuesta).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Slug o ID del contenido (ej. scary-movie-6, la-casa-del-dragon)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streams",
            "in": "query",
            "required": false,
            "description": "wait | true | 1 → espera a que los servidores estén resueltos y los incluye en la respuesta (más lento). Por defecto la respuesta es instantánea y `streams.status` vale 'pending'.",
            "schema": {
              "type": "string",
              "enum": [
                "wait",
                "true",
                "1"
              ]
            }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "season_1 | first_season → adjunta el primer episodio resuelto. streams → alias legacy de streams=wait.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalle obtenido con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaItemResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/media/{id}/streams": {
      "get": {
        "summary": "Resolver los enlaces reproducibles de un título",
        "description": "Camino lento aislado: resuelve los servidores del título (desde los enlaces persistidos si tienen menos de 24 h, si no scrapeando la fuente) y los guarda para las siguientes consultas. Pensado para llamarse al pulsar Reproducir, con la ficha ya pintada.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Slug o ID del contenido",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "deep",
            "in": "query",
            "required": false,
            "description": "1 | true → fuerza la fusión multifuente completa (TioPlus + FuegoCine). Más lento; devuelve el máximo de servidores disponibles.",
            "schema": {
              "type": "string",
              "enum": [
                "1",
                "true"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Enlaces resueltos con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StreamsResponse"
                }
              }
            }
          },
          "404": {
            "description": "El contenido solicitado no existe o no está disponible"
          }
        }
      }
    },
    "/api/v1/series/{id}": {
      "get": {
        "summary": "Obtener detalle de una serie (metadata instantánea)",
        "description": "Igual que /api/v1/media/{id} pero forzando el tipo serie: incluye temporadas y episodios. Los enlaces se piden en /api/v1/series/{id}/streams o por episodio.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Slug o ID de la serie",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streams",
            "in": "query",
            "required": false,
            "description": "wait | true | 1 → espera a la resolución de servidores.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalle obtenido con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaItemResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/series/{id}/streams": {
      "get": {
        "summary": "Resolver los enlaces reproducibles de una serie",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "deep",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Enlaces resueltos con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StreamsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/series/{id}/season/{season}/episode/{episode}": {
      "get": {
        "summary": "Obtener servidores de streaming para un episodio específico de una serie",
        "description": "Devuelve los reproductores de video embed reales (VidHide, Netu, UPFAST, etc.) para la temporada y episodio indicados de la serie.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Slug de la serie (ej. la-casa-del-dragon)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "season",
            "in": "path",
            "required": true,
            "description": "Número de temporada (ej. 1)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "episode",
            "in": "path",
            "required": true,
            "description": "Número de episodio (ej. 1)",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Servidores del episodio obtenidos con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EpisodeDetailResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/media/{id}/season/{season}/episode/{episode}": {
      "get": {
        "summary": "Obtener servidores de reproducción de un episodio de serie (Alias Media)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "season",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "episode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Servidores del episodio obtenidos con éxito"
          }
        }
      }
    },
    "/api/v1/home": {
      "get": {
        "summary": "Obtener el catálogo de inicio estilo Netflix (alias de /api/v1/feeds/home)",
        "description": "Mismo contrato y mismos parámetros que /api/v1/feeds/home.",
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "CL"
            }
          },
          {
            "name": "detail",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "card",
                "compact"
              ],
              "default": "card"
            }
          },
          {
            "name": "rows",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 40
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feed obtenido con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HomeFeedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/feeds/home": {
      "get": {
        "summary": "Obtener el catálogo de inicio estilo Netflix",
        "description": "Devuelve el hero rotatorio (`spotlight`, hasta 5 títulos con ficha completa) y alrededor de 15 carruseles temáticos (Top 10 del país, novedades, películas, series, mejor valoradas, anime, acción, comedia, terror, ciencia ficción, animación, drama, romance, aventura, crimen, documentales y clásicos). Cada fila se omite si no reúne al menos 8 títulos, de modo que nunca se publica un carrusel a medias.\n\nLas tarjetas viajan con la metadata completa (sinopsis, tagline, logo, duración, clasificación por edades, géneros, tráiler y número de temporadas), por lo que un cliente puede abrir su ficha emergente SIN ninguna petición adicional; solo los enlaces de reproducción se resuelven aparte en `/api/v1/media/{id}/streams`.",
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "description": "Código ISO del país, usado en el titular del Top 10.",
            "schema": {
              "type": "string",
              "default": "CL"
            }
          },
          {
            "name": "detail",
            "in": "query",
            "required": false,
            "description": "card (por defecto) → tarjetas con metadata completa. compact → proyección compacta clásica, payload mínimo.",
            "schema": {
              "type": "string",
              "enum": [
                "card",
                "compact"
              ],
              "default": "card"
            }
          },
          {
            "name": "rows",
            "in": "query",
            "required": false,
            "description": "Lista separada por comas de ids de fila (ej. action,anime,top_10_cl). Devuelve solo esas filas, para cargar el home por lotes.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Ítems por carrusel. Máximo 40.",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 40
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feed obtenido con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HomeFeedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/movies": {
      "get": {
        "summary": "Obtener catálogo de películas con paginación",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Número de página real sobre el índice general, empezando en 1."
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            },
            "description": "Cantidad de ítems por página. Alias compatible: size. Máximo 100."
          },
          {
            "name": "size",
            "in": "query",
            "description": "Alias de limit para definir la cantidad de ítems por página. Máximo 100.",
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          },
          {
            "name": "genre",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de películas obtenida con éxito"
          }
        }
      }
    },
    "/api/v1/series": {
      "get": {
        "summary": "Obtener catálogo de series con paginación",
