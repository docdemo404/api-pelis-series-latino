            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 100
            }
          },
          {
            "name": "genre",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de series obtenida con éxito"
          }
        }
      }
    },
    "/api/v1/media": {
      "get": {
        "summary": "Obtener catálogo general (películas + series)",
