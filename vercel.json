{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/docs/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/docs",
      "dest": "/public/index.html"
    },
    {
      "src": "/panel",
      "dest": "/public/panel.html"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
